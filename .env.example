# GitHub Repository SecretsмҷҖ лҸҷмқјн•ң мқҙлҰ„мңјлЎң EC2 .env мһ‘м„ұ

SPRING_DATASOURCE_URL=jdbc:postgresql://<RDS_HOST>:5432/<RDS_DB_NAME>
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=<RDS_PASSWORD к°’>
JWT_SECRET=<JWT_SECRET к°’>

