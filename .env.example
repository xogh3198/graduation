SPRING_DATASOURCE_URL=jdbc:postgresql://<RDS_HOST>:5432/db-2ne1
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=<RDS_PASSWORD>
JWT_SECRET=<32자_이상>
MQTT_BROKER_URL=tcp://mosquitto:1883

# 데모 라즈베리(센서 더미) — 식물 등록 시 deviceId에 아래 값 입력
# pi-demo-001

# AWS IoT Core — 라즈베리파이 S3 업로드 MQTT
AWS_IOT_ENABLED=true
AWS_IOT_ENDPOINT=amtgq6rjeeepu-ats.iot.us-east-1.amazonaws.com
AWS_IOT_CLIENT_ID=graduation-backend
AWS_IOT_PHOTO_TOPIC=plants/+/status/photo
AWS_IOT_PHOTO_REQUEST_TOPIC=plants/+/photo/request
AWS_IOT_PHOTO_RESPONSE_TOPIC_SUFFIX=photo/response
AWS_IOT_TELEMETRY_TOPIC=plants/+/telemetry
# ── 라즈베리파이 MQTT 토픽 (PLANT_ID=plant-1 기준) ──
# 상세: raspberry/mqtt.env.example, docs/PLANT_ID.md

# [Pi publish] 센서
# MQTT_TOPIC_TELEMETRY=plants/plant-1/telemetry

# [Pi publish] 사진 촬영 → Presigned URL 요청
# MQTT_TOPIC_PHOTO_REQUEST=plants/plant-1/photo/request
# payload: {"plantId":"plant-1","deviceId":"rpi4-001","contentType":"image/jpeg"}

# [Pi subscribe] Presigned URL 응답 → uploadUrl로 HTTP PUT
# MQTT_TOPIC_PHOTO_RESPONSE=plants/plant-1/photo/response

# [Pi subscribe] 급수/LED 제어
# MQTT_TOPIC_COMMAND=plants/plant-1/command
AWS_IOT_CERT_PATH=/app/certs/xxxx-certificate.pem.crt
AWS_IOT_PRIVATE_KEY_PATH=/app/certs/xxxx-private.pem.key
AWS_IOT_ROOT_CA_PATH=/app/certs/AmazonRootCA1.pem

# S3 — EC2 IAM Role 사용 (Access Key 불필요). presigned PUT URL 발급용
AWS_S3_BUCKET=<your-bucket-name>
AWS_REGION=us-east-1
AWS_S3_KEY_PREFIX=plants
AWS_S3_PRESIGN_EXPIRATION_MINUTES=15

# KVS WebRTC — EC2 IAM Role이 master/viewer Role을 AssumeRole 할 수 있어야 함
AWS_KVS_ENABLED=true
AWS_KVS_REGION=us-east-1
AWS_KVS_CHANNEL_NAME=inha-capstone-07-pi-camera-channel
AWS_KVS_MASTER_ROLE_ARN=arn:aws:iam::842544789367:role/inha-capstone-07-kvs-master-role
AWS_KVS_VIEWER_ROLE_ARN=arn:aws:iam::842544789367:role/inha-capstone-07-kvs-viewer-role
# Master 토큰 유효시간(초). IAM Role MaxSessionDuration 이하여야 함 (기본 3600=1시간)
# AWS_KVS_MASTER_DURATION_SECONDS=3600

# K3s AI 서버 (Windows Tailscale IP:30800 등)
AI_SERVER_BASE_URL=http://100.95.251.67:30800

# FCM — GitHub Secret FIREBASE_SERVICE_ACCOUNT_JSON (배포 시 EC2에 자동 생성)
# FCM_ENABLED=true
