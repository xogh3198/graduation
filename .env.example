# DB 이름: db-2ne1 (PostgreSQL에서 CREATE DATABASE "db-2ne1";)

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/db-2ne1
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=<RDS_PASSWORD>
JWT_SECRET=<32자_이상_랜덤>
MQTT_BROKER_URL=tcp://localhost:1883

# GitHub Secrets: RDS_HOST, RDS_DB_NAME=db-2ne1, RDS_PASSWORD, JWT_SECRET

# 더미 데이터 자동 생성 (최초 1회, users 테이블 비어 있을 때)
