# RDS_HOST = RDS 엔드포인트 (인스턴스 이름 db-2ne1 과 다름!)
# RDS_DB_NAME = PostgreSQL 안의 DB 이름 (예: db-2ne1) — RDS에 없으면 배포 시 자동 생성

SPRING_DATASOURCE_URL=jdbc:postgresql://<RDS_HOST>:5432/db-2ne1
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=<RDS_PASSWORD>
JWT_SECRET=<32자_이상>
MQTT_BROKER_URL=tcp://localhost:1883

# GitHub Secrets: RDS_HOST, RDS_DB_NAME, RDS_PASSWORD, JWT_SECRET
