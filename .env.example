SPRING_DATASOURCE_URL=jdbc:postgresql://<RDS_HOST>:5432/db-2ne1
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=<RDS_PASSWORD>
JWT_SECRET=<32자_이상>
MQTT_BROKER_URL=tcp://mosquitto:1883

# 데모 라즈베리(센서 더미) — 식물 등록 시 deviceId에 아래 값 입력
# pi-demo-001

# AWS IoT Core — 라즈베리파이 S3 업로드 MQTT
AWS_IOT_ENABLED=true
AWS_IOT_ENDPOINT=amtgq6rjeeepu-ats.iot.us-east-1.amazonaws.com
AWS_IOT_CLIENT_ID=graduation-backend
AWS_IOT_PHOTO_TOPIC=plants/+/status/photo
AWS_IOT_CERT_PATH=/app/certs/xxxx-certificate.pem.crt
AWS_IOT_PRIVATE_KEY_PATH=/app/certs/xxxx-private.pem.key
AWS_IOT_ROOT_CA_PATH=/app/certs/AmazonRootCA1.pem

# K3s AI 서버 (Windows Tailscale IP:30800 등)
AI_SERVER_BASE_URL=http://100.95.251.67:30800

# FCM (선택) — critical/병해 알림 푸시
FCM_ENABLED=false
FCM_SERVER_KEY=
