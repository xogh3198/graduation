# 라즈베리파이 AWS IoT MQTT 설정
# cp mqtt.env.example mqtt.env 후 값 수정

# 식물 등록 API 응답값 (POST /api/v1/plants)
# externalPlantId → PLANT_ID, deviceId → DEVICE_ID
PLANT_ID=plant-1
DEVICE_ID=rpi4-001

# AWS IoT Core (콘솔에서 라즈베리용 Thing 인증서 발급)
AWS_IOT_ENDPOINT=amtgq6rjeeepu-ats.iot.us-east-1.amazonaws.com
AWS_IOT_ROOT_CA=./certs/AmazonRootCA1.pem
AWS_IOT_CERT=./certs/device-certificate.pem.crt
AWS_IOT_PRIVATE_KEY=./certs/device-private.pem.key
AWS_IOT_CLIENT_ID=rpi4-001

# ── MQTT 토픽 (PLANT_ID에 맞게 plant-1 → plant-2 등 변경) ──

# [Pi → 서버] 센서 (주기 전송)
MQTT_TOPIC_TELEMETRY=plants/plant-1/telemetry

# [Pi → 서버] 사진 촬영 후 Presigned URL 요청 (1회)
MQTT_TOPIC_PHOTO_REQUEST=plants/plant-1/photo/request

# [서버 → Pi] Presigned URL 응답 (구독)
MQTT_TOPIC_PHOTO_RESPONSE=plants/plant-1/photo/response

# [서버 → Pi] 급수/LED + 라이브 영상 제어 (구독)
MQTT_TOPIC_COMMAND=plants/plant-1/command
# camera_live: action=start|stop, start 시 kvs.credentials 포함

# 사진 파일
PHOTO_FILE=./photo.jpg
PHOTO_CONTENT_TYPE=image/jpeg
